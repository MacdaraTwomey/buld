{
    "version": "0.2.0",
    "configurations": [

        {
            // This debugs programs compiled with Linux clang.
            // You can only run this configuration when vscode is remoted into linux fileystem.
            "name": "Debug from linux",
            "type": "lldb",
            "request": "launch",
            "program": "${workspaceFolder}/target/buld",
            //"args": "--graph graph.dot",
            "args": "sample/build/main.exe",
            "cwd": "${workspaceFolder}",
            //"env": {"LD_LIBRARY_PATH": "target"},
            //"args": ["target/test"],
            "terminal": "integrated",
            //"preLaunchTask": "buildLinux",
            "initCommands": [
                "type summary add --summary-string \"len: ${var.Length} ${var.Str%s}\" string"
            ]
        },
        {
            // This debugs programs compiled with clang.exe (and probably MSVC).
            // You can only run this configuration when vscode isn't remoted into linux fileystem.
            "name": "Debug from windows",
            "type": "cppvsdbg",
            "request": "launch",
            "program": "${workspaceFolder}/target/base",
            "symbolSearchPath": "${workspaceFolder}/code",
            "console": false,
            "visualizerFile": "${workspaceFolder}/my.natvis",
            "preLaunchTask": "build",
        },
        {
            "type": "lldb-dap",
            "request": "launch",
            "name": "LLDB DAP",
            "program": "${workspaceFolder}/target/base",
            "args": [ "test" ],
            "env": {
                "ASAN_OPTIONS": "detect_leaks=0",
            },
            "console": "integratedTerminal",
        }
    ],
}
